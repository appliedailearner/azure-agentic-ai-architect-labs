# Azure Agentic AI Reference Implementation - Environment Configuration Template
# Copy this file to .env and fill in your Azure credentials

# ============================================================================
# AZURE OPENAI CONFIGURATION
# ============================================================================

# Azure OpenAI Endpoint URL (format: https://YOUR-RESOURCE.openai.azure.com/)
OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/

# Azure OpenAI API Key (retrieve from Azure Portal)
OPENAI_KEY=your-openai-api-key-here

# OpenAI Model Name (e.g., gpt-4, gpt-35-turbo)
OPENAI_MODEL=gpt-4

# OpenAI Model Version (deployment name in Azure)
OPENAI_MODEL_VERSION=0125-preview

# ============================================================================
# AZURE SEARCH CONFIGURATION
# ============================================================================

# Azure Search Service Endpoint (format: https://YOUR-SERVICE.search.windows.net)
SEARCH_ENDPOINT=https://your-search-service.search.windows.net

# Azure Search Admin API Key
SEARCH_KEY=your-search-admin-key-here

# Azure Search Index Name (for RAG documents)
SEARCH_INDEX=agentic-ai-docs

# ============================================================================
# COSMOS DB CONFIGURATION (OPTIONAL)
# ============================================================================

# Cosmos DB Endpoint URL
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/

# Cosmos DB Primary Key
COSMOS_KEY=your-cosmos-primary-key-here

# Cosmos DB Database Name
COSMOS_DATABASE=agentic-ai-db

# Cosmos DB Container for Agent State
COSMOS_CONTAINER=agent-state

# ============================================================================
# AZURE KEY VAULT CONFIGURATION
# ============================================================================

# Key Vault URI (format: https://YOUR-VAULT.vault.azure.net/)
KEYVAULT_URI=https://your-keyvault.vault.azure.net/

# Key Vault Tenant ID
KEYVAULT_TENANT_ID=your-azure-tenant-id

# Key Vault Client ID (Service Principal)
KEYVAULT_CLIENT_ID=your-client-id

# Key Vault Client Secret (Service Principal)
KEYVAULT_CLIENT_SECRET=your-client-secret

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment (dev, staging, prod)
ENVIRONMENT=dev

# Application Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable Debug Mode (true/false)
DEBUG=false

# Application Port (for FastAPI server)
APP_PORT=8000

# Application Host
APP_HOST=0.0.0.0

# ============================================================================
# AZURE SUBSCRIPTION INFORMATION
# ============================================================================

# Azure Subscription ID
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Azure Resource Group Name
AZURE_RESOURCE_GROUP=rg-agentic-ai-dev

# Azure Region
AZURE_REGION=eastus

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Terraform State Backend (azure/local)
TERRAFORM_BACKEND=local

# Terraform Auto Approve
TERRAFORM_AUTO_APPROVE=false

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Request Timeout (seconds)
REQUEST_TIMEOUT=30

# Max Retries for API Calls
MAX_RETRIES=3

# Enable Performance Monitoring
ENABLE_MONITORING=true

# Custom Headers (JSON format)
CUSTOM_HEADERS={}

# ============================================================================
# INSTRUCTIONS
# ============================================================================
# 
# 1. Copy this file and rename to .env
# 2. Fill in all required values (marked with 'your-' prefix)
# 3. Keep this file secure and never commit it to version control
# 4. Use Azure Key Vault for production deployments
# 5. Refer to DEPLOYMENT-GUIDE.md for detailed setup instructions
# 
